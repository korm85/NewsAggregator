# Get a bot token from @BotFather on Telegram (free, instant)
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDeeffGGHHiijjKKLLmmNNoopp

# Your output channel's numeric ID or @username
# To get the numeric ID: forward a message from the channel to @userinfobot
OUTPUT_CHANNEL_ID=@my_unique_news

# Comma-separated public channel usernames to monitor
SOURCE_CHANNELS=@bbcnews,@cnn,@reuters

# Optional tuning (set as GitHub Actions Variables, not Secrets)
DEDUP_WINDOW_HOURS=48
SIMILARITY_THRESHOLD=0.6
