# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# Your Telegram phone number (with country code)
TELEGRAM_PHONE=+1234567890

# The username or invite link of the channel where unique news will be posted
# Create a private channel in Telegram, add yourself as admin, paste its username here
# Example: @my_unique_news or https://t.me/+abc123
OUTPUT_CHANNEL=@your_output_channel

# Comma-separated list of source channel usernames or links to monitor
# Example: @bbcnews,@cnn,@reuters
SOURCE_CHANNELS=@channel1,@channel2,@channel3

# How many hours back to remember articles for deduplication (default 48)
DEDUP_WINDOW_HOURS=48

# Similarity threshold 0.0-1.0. Higher = stricter (only near-identical flagged as dupe).
# 0.6 is a good default — catches rephrased duplicates without false positives.
SIMILARITY_THRESHOLD=0.6

# Optional: session file name (no extension)
SESSION_NAME=news_aggregator
